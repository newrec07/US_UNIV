generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// packages/domain/src/system/user.ts 의 User를 그대로 따른다.
enum UserRole {
  student
  parent
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  role      UserRole
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
